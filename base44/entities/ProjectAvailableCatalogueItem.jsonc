          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "staff"
              }
            }
          ]
        }
      }
    },
    "customer_note": {
      "type": "string"
    },
    "price_override": {
      "type": "number",
      "rls": {
        "read": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "staff"
              }
            }
          ]
        },
        "write": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "staff"
              }
            }
          ]
        }
      }
    },
    "allowance_impact_override": {
      "type": "number",
      "rls": {
        "read": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "staff"
              }
            }
          ]
        },
        "write": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "staff"
              }
            }
          ]
        }
      }
    },
    "is_available": {
      "type": "boolean",
      "default": true
    },
    "custom_allowance": {
      "type": "number",
      "rls": {
        "read": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
