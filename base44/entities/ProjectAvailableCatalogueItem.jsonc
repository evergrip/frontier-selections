      "type": "string"
    },
    "catalogue_item_id": {
      "type": "string"
    },
    "display_order": {
      "type": "number",
      "default": 0
    },
    "is_recommended": {
      "type": "boolean",
      "default": false
    },
    "staff_note": {
      "type": "string",
